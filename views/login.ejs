<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - WatchList</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .guest-separator {
            margin: 20px 0;
            text-align: center;
            border-bottom: 1px solid #333;
            line-height: 0.1em;
        }
        .guest-separator span {
            background: #222;
            padding: 0 10px;
            color: #666;
            font-size: 0.8rem;
            text-transform: uppercase;
        }
        .btn-secondary-outline {
            display: block;
            text-align: center;
            padding: 12px;
            border: 1px solid #444;
            border-radius: 6px;
            color: #bbb;
            text-decoration: none;
            transition: all 0.3s;
            font-weight: bold;
            margin-top: 10px;
        }
        .btn-secondary-outline:hover {
            background: #333;
            color: white;
            border-color: #666;
        }
    </style>
</head>
<body>
<main class="content-wrapper">
    <div class="edit-container">
        <h1 class="brand-logo">WatchList</h1>
        <h2>Login to Your Account</h2>

        <% if (error) { %>
            <div class="error-banner"><%= error %></div>
        <% } %>

        <form action="/login" method="POST" class="styled-form">
            <div class="form-group">
                <label>Username or Email</label>
                <input type="text" name="username" required>
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" required>
            </div>

            <button type="submit" class="btn-save">Login</button>

            <div class="guest-separator">
                <span>OR</span>
            </div>

            <a href="/search" class="btn-secondary-outline">Browse as Guest</a>
        </form>

        <p class="auth-footer-text">
            Don't have an account? <a href="/register">Register here</a>
        </p>
    </div>
</main>

<%- include('partials/footer.ejs') %>
</body>
</html>